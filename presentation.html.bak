<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>数据会说谎，也会讲故事——当可视化遇见人的成长</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Space+Grotesk:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0d0d0d;--bg-card:#141413;--bg-card-inner:#1a1a18;--accent:#D4A574;--accent-dim:rgba(212,165,116,0.12);--text:#E8E0D4;--text-muted:#8A8078;--text-dim:#5A5450;--border:rgba(232,224,212,0.08);--border-accent:rgba(212,165,116,0.2);--radius-lg:20px;--radius-md:12px;--ease-out:cubic-bezier(0.32,0.72,0,1)}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'Noto Sans SC','Space Grotesk',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
h1,h2,h3{font-family:'Noto Serif SC','DM Serif Display',serif;font-weight:600;line-height:1.2}

/* Presentation Container */
#presentation{position:relative;width:100vw;height:100dvh;overflow:hidden}

/* Slide */
.slide{position:absolute;inset:0;opacity:0;visibility:hidden;pointer-events:none;display:flex;align-items:center;transition:opacity 0.6s var(--ease-out);padding:clamp(2rem,5vh,4rem) clamp(2rem,6vw,6rem);overflow-y:auto}
.slide.active{opacity:1;visibility:visible;pointer-events:auto}
.slide-inner{width:100%;max-width:72rem;margin:0 auto}

/* Progress Bar */
#progress-bar{position:fixed;top:0;left:0;height:2px;background:var(--accent);z-index:100;width:0%;transition:width 0.4s ease-out}

/* Slide Counter */
.slide-counter{position:fixed;bottom:1.5rem;right:2rem;z-index:100;font-family:'Space Grotesk',monospace;font-size:0.8rem;color:var(--text-dim);letter-spacing:0.12em}
.slide-counter .cur{color:var(--accent);font-size:1.1rem}

/* Dot Nav */
#dot-nav{position:fixed;right:1.75rem;top:50%;transform:translateY(-50%);z-index:100;display:flex;flex-direction:column;gap:14px}
.nav-dot{width:8px;height:8px;border-radius:50%;background:var(--text-dim);border:none;padding:0;cursor:pointer;opacity:0.3;transition:all 0.4s var(--ease-out)}
.nav-dot.active{background:var(--accent);opacity:1;transform:scale(1.5);box-shadow:0 0 10px rgba(212,165,116,0.4)}
.nav-dot:hover{opacity:0.7;transform:scale(1.2)}

/* Grain Overlay */
#grain-overlay{position:fixed;inset:0;z-index:50;pointer-events:none;opacity:0.035}

/* Background Blobs */
#ambient-bg{position:fixed;inset:0;z-index:0;pointer-events:none}
.ambient-blob{position:absolute;border-radius:50%;filter:blur(120px);opacity:0.5}
.blob-1{width:clamp(300px,50vw,600px);height:clamp(300px,50vw,600px);background:radial-gradient(ellipse,rgba(212,165,116,0.08),transparent 70%);top:5%;left:-10%;animation:floatA 20s ease-in-out infinite}
.blob-2{width:clamp(250px,40vw,500px);height:clamp(250px,40vw,500px);background:radial-gradient(ellipse,rgba(212,165,116,0.05),transparent 70%);bottom:10%;right:-5%;animation:floatB 25s ease-in-out infinite}
@keyframes floatA{0%,100%{transform:translate(0,0)}50%{transform:translate(50px,40px)}}
@keyframes floatB{0%,100%{transform:translate(0,0)}50%{transform:translate(-40px,-30px)}}

/* Typography */
.hero-title{font-size:clamp(2.5rem,5.5vw,5rem);color:var(--text);margin-bottom:1.5rem}
.hero-subtitle{font-size:clamp(1.1rem,2.2vw,1.8rem);color:var(--accent);font-weight:300;margin-bottom:2rem}
.section-title{font-size:clamp(1.75rem,3.2vw,2.75rem);color:var(--text);margin-bottom:0.75rem}
.section-subtitle{font-size:clamp(0.95rem,1.3vw,1.15rem);color:var(--text-muted);font-weight:300;max-width:55rem;line-height:1.7}
.label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.18em;color:var(--accent);font-weight:600;margin-bottom:1rem;display:block}
.body-text{font-size:0.88rem;color:var(--text-muted);line-height:1.75}
.highlight{color:var(--accent);font-weight:500}

/* Card */
.card-outer{background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2px}
.card-inner{background:var(--bg-card-inner);border-radius:calc(var(--radius-lg) - 2px);padding:clamp(1rem,1.5vw,1.5rem);box-shadow:inset 0 1px 1px rgba(255,255,255,0.03)}

/* Grid */
.bento{display:grid;grid-template-columns:repeat(12,1fr);gap:16px;grid-auto-flow:dense}
.span-7{grid-column:span 7}.span-5{grid-column:span 5}.span-6{grid-column:span 6}.span-12{grid-column:span 12}
@media(max-width:900px){.span-7,.span-5,.span-6{grid-column:span 12}}

/* Table */
.data-table{width:100%;border-collapse:separate;border-spacing:0;font-size:0.82rem}
.data-table th{font-weight:600;font-size:0.72rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--accent);padding:12px 16px;text-align:left;border-bottom:1px solid var(--border-accent);background:rgba(212,165,116,0.04)}
.data-table td{padding:10px 16px;border-bottom:1px solid var(--border);color:var(--text-muted);vertical-align:top}
.data-table td strong{color:var(--text);font-weight:500}
.data-table tr:last-child td{border-bottom:none}

/* Callout */
.callout{border:1px solid var(--border-accent);border-radius:var(--radius-md);padding:1rem 1.5rem;background:var(--accent-dim)}
.callout-text{font-size:0.88rem;color:var(--text);line-height:1.7;font-family:'DM Serif Display','Noto Serif SC',serif;font-style:italic}
.callout-meta{font-size:0.72rem;color:var(--text-dim);margin-top:6px;font-weight:500}

/* Discussion */
.discussion{display:flex;gap:12px;align-items:flex-start;padding:1rem 1.25rem;border:1px dashed var(--border-accent);border-radius:var(--radius-md);background:rgba(212,165,116,0.02)}
.discussion-icon{flex-shrink:0;width:26px;height:26px;border-radius:50%;border:1.5px solid var(--accent);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--accent);font-weight:600;margin-top:1px}
.discussion p{font-size:0.85rem;color:var(--text);line-height:1.65;font-weight:300}

/* Stage List */
.stage-list{list-style:none;display:flex;flex-direction:column;gap:8px;counter-reset:s}
.stage-item{display:flex;gap:12px;align-items:flex-start;counter-increment:s}
.stage-number{flex-shrink:0;width:26px;height:26px;border-radius:50%;border:1px solid var(--border-accent);display:flex;align-items:center;justify-content:center;font-size:0.65rem;font-weight:600;color:var(--accent);font-family:'Space Grotesk',monospace}
.stage-name{font-weight:600;color:var(--text);font-size:0.85rem;margin-bottom:2px}
.stage-desc{color:var(--text-muted);font-size:0.78rem;line-height:1.55}

/* Principle Grid */
.principle-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px}
.principle-card{border:1px solid var(--border);border-radius:var(--radius-md);padding:1.25rem;background:var(--bg-card-inner);transition:all 0.5s var(--ease-out)}
.principle-card:hover{border-color:var(--border-accent);transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,0.25)}
.principle-num{font-family:'DM Serif Display',serif;font-size:2rem;color:var(--accent);opacity:0.25;line-height:1;margin-bottom:6px}
.principle-title{font-size:0.9rem;color:var(--text);font-weight:500;margin-bottom:6px}
.principle-desc{font-size:0.8rem;color:var(--text-muted);line-height:1.6}

/* Strategy Cards */
.strategy-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px}
.strategy-card{text-align:center;padding:1.25rem 0.75rem;border:1px solid var(--border);border-radius:var(--radius-lg);transition:all 0.5s var(--ease-out)}
.strategy-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 8px 20px rgba(0,0,0,0.25)}
.strategy-name{font-family:'Noto Serif SC','DM Serif Display',serif;font-size:0.92rem;color:var(--text);margin:0.75rem 0 0.375rem}
.strategy-note{font-size:0.75rem;color:var(--text-muted);line-height:1.5}

/* Image Container */
.img-frame{border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border);position:relative;background:var(--bg-card)}
.img-frame img{width:100%;height:auto;display:block;transition:transform 0.6s var(--ease-out)}
.img-frame:hover img{transform:scale(1.02)}
.img-caption{position:absolute;bottom:0;left:0;right:0;padding:1rem;background:linear-gradient(transparent,rgba(13,13,13,0.85));font-size:0.72rem;color:var(--text-muted);letter-spacing:0.05em}

/* Duality */
.duality{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:768px){.duality{grid-template-columns:1fr}}
.duality-pos{border:1px solid rgba(74,170,120,0.2);border-radius:var(--radius-md);padding:1.25rem;background:rgba(74,170,120,0.06)}
.duality-neg{border:1px solid rgba(200,80,60,0.15);border-radius:var(--radius-md);padding:1.25rem;background:rgba(200,80,60,0.05)}
.duality-label{font-size:0.68rem;text-transform:uppercase;letter-spacing:0.15em;font-weight:700;margin-bottom:0.75rem}
.duality-pos .duality-label{color:#4aaa78}
.duality-neg .duality-label{color:#c8503c}
.duality-list{list-style:none;padding:0}
.duality-list li{font-size:0.82rem;color:var(--text-muted);line-height:1.65;padding:4px 0}
.duality-list li::before{content:'';display:inline-block;width:5px;height:5px;border-radius:50%;margin-right:8px;vertical-align:middle}
.duality-pos .duality-list li::before{background:#4aaa78}
.duality-neg .duality-list li::before{background:#c8503c}

/* Divider */
.divider{width:48px;height:2px;background:var(--accent);opacity:0.4;margin:1.25rem 0}

/* Closing */
.closing-title-big{font-size:clamp(2.5rem,6vw,5.5rem);color:var(--accent);margin-bottom:0.5rem}
.closing-subtitle{font-size:clamp(1rem,1.6vw,1.3rem);color:var(--text-muted);max-width:55rem;line-height:1.8;font-family:'DM Serif Display','Noto Serif SC',serif;font-style:italic}
.thanks-line{font-family:'DM Serif Display','Noto Serif SC',serif;font-size:clamp(1.25rem,2vw,1.75rem);color:var(--accent);margin-top:2rem}

/* Ref Tags */
.ref-tags{display:flex;flex-wrap:wrap;gap:8px 16px;margin-top:1.5rem}
.ref-tag{font-size:0.72rem;color:var(--text-dim);padding:4px 10px;border:1px solid var(--border);border-radius:999px;background:rgba(26,26,24,0.5);font-family:'Space Grotesk',monospace;letter-spacing:0.04em}

/* Slide Anim */
.anim-in{opacity:0;transform:translateY(24px)}

/* Nav Hint */
.nav-hint{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);font-size:0.68rem;color:var(--text-dim);letter-spacing:0.12em;text-transform:uppercase;z-index:100;display:flex;gap:16px}
.nav-hint kbd{background:var(--bg-card);border:1px solid var(--border);border-radius:4px;padding:2px 6px;font-size:0.65rem;font-family:'Space Grotesk',monospace}

/* Responsive */
@media(max-width:768px){
  #dot-nav{display:none}
  .nav-hint{display:none}
  .slide{padding:clamp(1rem,3vh,2rem) clamp(1rem,4vw,1.5rem)}
  .strategy-row{grid-template-columns:1fr}
  .principle-grid{grid-template-columns:1fr}
}
</style>
</head>
<body>

<div id="presentation">

  <!-- Progress Bar -->
  <div id="progress-bar"></div>

  <!-- Gradient Background -->
  <div id="ambient-bg">
    <div class="ambient-blob blob-1"></div>
    <div class="ambient-blob blob-2"></div>
  </div>

  <!-- SVG Grain -->
  <svg id="grain-overlay" xmlns="http://www.w3.org/2000/svg">
    <filter id="noise"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter>
    <rect width="100%" height="100%" filter="url(#noise)"/>
  </svg>

  <!-- Dot Nav -->
  <nav id="dot-nav" aria-label="Slide navigation">
    <button class="nav-dot active" data-slide="0" aria-label="Slide 1"></button>
    <button class="nav-dot" data-slide="1" aria-label="Slide 2"></button>
    <button class="nav-dot" data-slide="2" aria-label="Slide 3"></button>
    <button class="nav-dot" data-slide="3" aria-label="Slide 4"></button>
    <button class="nav-dot" data-slide="4" aria-label="Slide 5"></button>
    <button class="nav-dot" data-slide="5" aria-label="Slide 6"></button>
  </nav>

  <!-- Slide Counter -->
  <div class="slide-counter"><span class="cur">01</span> / 06</div>

  <!-- Navigation Hint -->
  <div class="nav-hint">
    <span><kbd>↑</kbd> <kbd>↓</kbd> 切换页面</span>
    <span><kbd>←</kbd> <kbd>→</kbd> 导航</span>
  </div>

  <!-- ===================== SLIDE 0: HERO ===================== -->
  <section class="slide active" data-index="0">
    <div class="slide-inner" style="max-width:60rem;">
      <div class="divider anim-in"></div>
      <h1 class="hero-title anim-in">数据会说谎，也会讲故事</h1>
      <p class="hero-subtitle anim-in">当可视化遇见人的成长</p>
      <div class="divider anim-in"></div>
      <p class="body-text anim-in" style="font-size:1rem;line-height:1.85;max-width:55rem;font-style:italic;opacity:0.7;margin-bottom:2rem;">
        技术让数据采集变得极其容易，但从数据到意义的"翻译"工作几乎没有人在做。这个翻译工作，恰恰是设计师的核心价值所在。
      </p>
      <div class="bento anim-in" style="grid-template-columns:1fr 1fr;gap:16px;max-width:48rem;">
        <div class="img-frame">
          <img src="resources/spotify-wrapped-01.png" alt="Spotify 2018 Wrapped" loading="lazy">
          <div class="img-caption">Spotify Wrapped — 个人数据叙事设计</div>
        </div>
        <div class="img-frame">
          <img src="resources/duolingo-streak.png" alt="Duolingo Streak" loading="lazy">
          <div class="img-caption">Duolingo Streak — 游戏化连续打卡</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SLIDE 1: 数据 ≠ 信息 ≠ 意义 ================= -->
  <section class="slide" data-index="1">
    <div class="slide-inner">
      <div class="bento" style="align-items:start;">
        <div class="span-7">
          <span class="label anim-in">观点一</span>
          <h2 class="section-title anim-in">数据 ≠ 信息 ≠ 意义</h2>
          <p class="section-subtitle anim-in" style="max-width:48rem;margin-bottom:1.5rem;">源自DIKW金字塔——数据是沉默的，信息回答"发生了什么"，意义回答"这对你意味着什么"。</p>

          <div class="card-outer anim-in">
            <div class="card-inner" style="padding:1.25rem;">
              <ul class="stage-list">
                <div class="stage-item"><span class="stage-number">D</span><div><div class="stage-name">数据（Data）</div><div class="stage-desc">脱离语境的原始事实。"62%"本身什么都说明不了。</div></div></div>
                <div class="stage-item"><span class="stage-number">I</span><div><div class="stage-name">信息（Information）</div><div class="stage-desc">被赋予语境的数据。"比上月提升了7个百分点"。</div></div></div>
                <div class="stage-item"><span class="stage-number">M</span><div><div class="stage-name">意义（Meaning）</div><div class="stage-desc">被赋予解释和情感。"你正在突破瓶颈期"。</div></div></div>
              </ul>
            </div>
          </div>
        </div>

        <div class="span-5" style="display:flex;flex-direction:column;gap:14px;">
          <div class="card-outer anim-in">
            <div class="card-inner" style="padding:1.15rem;">
              <span class="label" style="margin-bottom:0.75rem;">个人信息化五阶段模型</span>
              <ul class="stage-list">
                <div class="stage-item"><span class="stage-number">1</span><div><div class="stage-name">准备</div><div class="stage-desc">决定追踪什么</div></div></div>
                <div class="stage-item"><span class="stage-number">2</span><div><div class="stage-name">收集</div><div class="stage-desc">实际数据采集</div></div></div>
                <div class="stage-item"><span class="stage-number">3</span><div><div class="stage-name">整合</div><div class="stage-desc">数据组织与清洗</div></div></div>
                <div class="stage-item"><span class="stage-number">4</span><div><div class="stage-name">反思</div><div class="stage-desc">最关键也最薄弱的环节</div></div></div>
                <div class="stage-item"><span class="stage-number">5</span><div><div class="stage-name">行动</div><div class="stage-desc">基于洞察做出改变</div></div></div>
              </ul>
              <p class="body-text" style="font-size:0.75rem;margin-top:0.75rem;font-style:italic;color:var(--accent);">Ian Li et al., CHI 2010</p>
            </div>
          </div>
        </div>
      </div>

      <div style="margin-top:1.5rem;">
        <span class="label anim-in">真实用户痛点</span>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-top:12px;">
          <div class="callout anim-in">
            <p class="callout-text">"听劝，准备放弃网球了"</p>
            <p class="callout-meta">2680赞 · 在缺乏"成长叙事"时，大脑采用"缺陷扫描"模式</p>
          </div>
          <div class="callout anim-in">
            <p class="callout-text">"打中甜区的'啵啵'声太治愈了！"</p>
            <p class="callout-meta">2371赞 · 感官层面的进步锚点</p>
          </div>
          <div class="callout anim-in">
            <p class="callout-text">"能拉起来了！好开心！"</p>
            <p class="callout-meta">571赞 · "第一次"就是突破时刻</p>
          </div>
        </div>
      </div>

      <div style="margin-top:1.25rem;">
        <div class="discussion anim-in">
          <div class="discussion-icon">?</div>
          <p>你希望你的APP在你打开它的时候，第一眼让你看到什么？数据仪表盘和体检报告有什么相似之处？</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SLIDE 2: 可视化是一种修辞行为 ================= -->
  <section class="slide" data-index="2">
    <div class="slide-inner">
      <div style="max-width:55rem;">
        <span class="label anim-in">观点二</span>
        <h2 class="section-title anim-in">可视化是一种修辞行为</h2>
        <p class="section-subtitle anim-in" style="max-width:55rem;margin-bottom:1.5rem;">每一张数据可视化都不是对现实的"镜像反映"，而是经过选择和建构的修辞行为。——Hullman & Diakopoulos, 2011</p>
      </div>

      <div class="bento" style="margin-bottom:1.25rem;">
        <div class="span-7">
          <div class="card-outer anim-in">
            <div class="card-inner" style="padding:0;">
              <table class="data-table" style="padding:1rem;">
                <thead><tr><th>损失框架（Loss Frame）</th><th>增益框架（Gain Frame）</th></tr></thead>
                <tbody>
                  <tr><td>"你的正手失误率是<strong>35%</strong>"</td><td>"你的正手上线率是<strong>65%</strong>"</td></tr>
                  <tr><td>"你比同水平选手慢<strong>15%</strong>"</td><td>"你的速度已达到<strong>85%分位</strong>"</td></tr>
                  <tr><td>"本月训练天数<strong>不足目标</strong>"</td><td>"本月你已在球场度过<strong>12天</strong>"</td></tr>
                  <tr><td>"你的反手是你<strong>最弱的环节</strong>"</td><td>"你的正手已经是你的<strong>可靠武器</strong>"</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="span-5">
          <div class="img-frame" style="height:100%;">
            <img src="resources/spotify-wrapped-03.webp" alt="Spotify Wrapped Colorful Data Cards" loading="lazy" style="height:300px;object-fit:cover;">
            <div class="img-caption">Spotify Wrapped 2018 — 框架效应的极致运用</div>
          </div>
        </div>
      </div>

      <div class="strategy-row anim-in" style="margin-bottom:1.25rem;">
        <div class="strategy-card">
          <span style="font-size:1.5rem;display:block;">📦</span>
          <div class="strategy-name">时间胶囊叙事</div>
          <div class="strategy-note">激活自传体记忆，产生情感共鸣</div>
        </div>
        <div class="strategy-card">
          <span style="font-size:1.5rem;display:block;">🏷</span>
          <div class="strategy-name">身份建构</div>
          <div class="strategy-note">帮用户回答"我是谁"</div>
        </div>
        <div class="strategy-card">
          <span style="font-size:1.5rem;display:block;">🪙</span>
          <div class="strategy-name">社交货币</div>
          <div class="strategy-note">每一帧都是可分享的"故事"</div>
        </div>
        <div class="strategy-card">
          <span style="font-size:1.5rem;display:block;">✨</span>
          <div class="strategy-name">增益性框架</div>
          <div class="strategy-note">从不说负面，将尴尬包装为个性</div>
        </div>
      </div>

      <div class="bento" style="gap:16px;">
        <div class="span-6">
          <div class="card-outer anim-in">
            <div class="card-inner">
              <span class="label">Giorgia Lupi · 数据人文主义</span>
              <div class="img-frame" style="margin-top:0.75rem;">
                <img src="resources/dear-data-postcard.png" alt="Dear Data hand-drawn postcard" loading="lazy">
                <div class="img-caption">Dear Data — 手绘明信片记录生活数据，一年52张</div>
              </div>
              <p class="body-text" style="font-size:0.82rem;margin-top:0.75rem;">"我们不应该只关注数字、技术和算法，而应该关注生成数据的人。"——当数据被发现带有个人痕迹和不完美时，它变得亲密而有意义。</p>
            </div>
          </div>
        </div>
        <div class="span-6">
          <div class="card-outer anim-in" style="margin-bottom:12px;">
            <div class="card-inner" style="padding:1rem;">
              <span class="label">叙事可视化七种体裁</span>
              <p class="body-text" style="font-size:0.82rem;">杂志风格、注释图表、分区海报、流程图、漫画条、幻灯片放映、影片/动画。你们的课题最值得关注的是<strong style="color:var(--accent);">幻灯片放映</strong>——Spotify Wrapped的形式。</p>
            </div>
          </div>
          <div class="discussion">
            <div class="discussion-icon">?</div>
            <p>如果Spotify Wrapped告诉你"你32%的时间都在重复同一首歌"，你还会分享吗？为什么不这样说？</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SLIDE 3: 人需要"看见自己在变好" ================= -->
  <section class="slide" data-index="3">
    <div class="slide-inner">
      <div class="bento" style="align-items:start;">
        <div class="span-6">
          <span class="label anim-in">观点三</span>
          <h2 class="section-title anim-in">人需要"看见自己在变好"</h2>
          <p class="section-subtitle anim-in" style="max-width:42rem;margin-bottom:1.25rem;">自我效能理论（Bandura, 1977）——不是"你实际上能不能做到"，而是"相不相信自己能做到"。</p>

          <div class="card-outer anim-in" style="margin-bottom:12px;">
            <div class="card-inner">
              <table class="data-table">
                <thead><tr><th>高自我效能</th><th>低自我效能</th></tr></thead>
                <tbody>
                  <tr><td>视作<strong>需要掌握的挑战</strong></td><td>视作<strong>需要回避的威胁</strong></td></tr>
                  <tr><td>坚持不懈</td><td>迅速放弃</td></tr>
                  <tr><td>失败归因于<strong>努力不足</strong></td><td>失败归因于<strong>能力不足</strong></td></tr>
                </tbody>
              </table>
            </div>
          </div>

          <div class="card-outer anim-in">
            <div class="card-inner" style="padding:1rem;">
              <span class="label" style="margin-bottom:0.5rem;">自我效能四来源</span>
              <ul class="stage-list" style="gap:6px;">
                <div class="stage-item"><span class="stage-number">1</span><div><div class="stage-name">掌握经验</div><div class="stage-desc">直接的成功体验，影响力最强</div></div></div>
                <div class="stage-item"><span class="stage-number">2</span><div><div class="stage-name">替代经验</div><div class="stage-desc">"如果他能做到，我也能"</div></div></div>
                <div class="stage-item"><span class="stage-number">3</span><div><div class="stage-name">言语说服</div><div class="stage-desc">来自他人的鼓励和肯定</div></div></div>
                <div class="stage-item"><span class="stage-number">4</span><div><div class="stage-name">生理情绪状态</div><div class="stage-desc">从身体感受推断自我效能</div></div></div>
              </ul>
            </div>
          </div>
        </div>

        <div class="span-6" style="display:flex;flex-direction:column;gap:14px;">
          <div class="duality anim-in">
            <div class="duality-pos">
              <div class="duality-label">Duolingo 正面</div>
              <ul class="duality-list">
                <li>留存率从12%提升到55%</li>
                <li>情感锚点 · 身份标记 · 社交货币</li>
                <li>利用损失厌恶心理维持习惯</li>
              </ul>
            </div>
            <div class="duality-neg">
              <div class="duality-label">Duolingo 反面</div>
              <ul class="duality-list">
                <li>倾向选择简单练习维持Streak</li>
                <li>Streak断裂后彻底放弃，而非重新开始</li>
                <li>外在动机侵蚀内在动机</li>
              </ul>
            </div>
          </div>

          <div class="card-outer anim-in">
            <div class="card-inner" style="padding:1.25rem;">
              <span class="label">学习平台期的神经科学</span>
              <p class="body-text" style="font-size:0.85rem;margin-bottom:0.75rem;">平台期不是"没有进步"，而是大脑正在进行<strong class="highlight">运动记忆的巩固</strong>——突触强化、自动化转移（前额叶到基底神经节）、干扰消除。</p>
              <p class="body-text" style="font-size:0.82rem;font-style:italic;color:var(--accent);">平台期之后往往伴随着突然的表现跃升——"突然有一天就通了"。</p>
            </div>
          </div>

          <div class="discussion anim-in">
            <div class="discussion-icon">?</div>
            <p>Duolingo让你害怕断Streak，Spotify Wrapped让你期待年底总结——哪种情绪设计更适合运动训练？</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SLIDE 4: 这不只是一个网球问题 ================= -->
  <section class="slide" data-index="4">
    <div class="slide-inner">
      <div style="max-width:55rem;">
        <span class="label anim-in">观点四</span>
        <h2 class="section-title anim-in">这不只是一个网球问题</h2>
        <p class="section-subtitle anim-in" style="max-width:55rem;margin-bottom:1.5rem;">"进步真实发生着，但人感知不到"——学乐器、学语言、健身、学编程，都存在同样的认知偏差。</p>
      </div>

      <div class="principle-grid anim-in" style="margin-bottom:1.5rem;">
        <div class="principle-card">
          <div class="principle-num">01</div>
          <p class="principle-title">锚定过去的自己</p>
          <p class="principle-desc">"时间旅行"功能——一键对比"30天前的你 vs 今天的你"</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">02</div>
          <p class="principle-title">纪念"第一次"</p>
          <p class="principle-desc">第一次成功发球、第一次赢得一局——标志能力的质变</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">03</div>
          <p class="principle-title">重新定义停滞</p>
          <p class="principle-desc">将"停滞"变为"巩固"，提供科学解释</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">04</div>
          <p class="principle-title">让数据说人话</p>
          <p class="principle-desc">从技术语言到日常语言，从客观述到主观体验</p>
        </div>
        <div class="principle-card">
          <div class="principle-num">05</div>
          <p class="principle-title">设计"优雅的中断"</p>
          <p class="principle-desc">回来时不说"你已经X天没练了"，而说"让我们继续"</p>
        </div>
      </div>

      <div class="bento" style="gap:16px;">
        <div class="span-5">
          <div class="card-outer anim-in">
            <div class="card-inner">
              <span class="label">"能力罐头"（Can-Do Jar）</span>
              <p class="body-text" style="font-size:0.88rem;margin-bottom:0.75rem;line-height:1.8;">每当你发现自己"能做到一件以前做不到的事"，就在一张纸条上写下来放进罐子里。当你感到沮丧时，打开罐子，看看里面已经积累多少。数据可视化系统本质上就是一个<strong class="highlight">数字化的"能力罐头"</strong></p>
              <div class="img-frame" style="margin-top:0.75rem;">
                <img src="resources/data-humanism.png" alt="Spotify Decade Wrapped data visualization" loading="lazy" style="height:200px;object-fit:cover;">
                <div class="img-caption">用数据讲述个人成长故事的设计</div>
              </div>
            </div>
          </div>
        </div>

        <div class="span-7">
          <div class="card-outer anim-in" style="margin-bottom:12px;">
            <div class="card-inner">
              <span class="label">伦理边界：赋能 vs 操控</span>
              <ul class="stage-list" style="gap:8px;">
                <div class="stage-item"><span class="stage-number" style="border-style:none;background:rgba(212,165,116,0.15);">1</span><div><div class="stage-name">不篡改数据本身</div><div class="stage-desc">框架效应改变的是呈现方式，而非数据事实</div></div></div>
                <div class="stage-item"><span class="stage-number" style="border-style:none;background:rgba(212,165,116,0.15);">2</span><div><div class="stage-name">不隐瞒关键风险</div><div class="stage-desc">可能导致伤害的动作模式必须被清晰传达</div></div></div>
                <div class="stage-item"><span class="stage-number" style="border-style:none;background:rgba(212,165,116,0.15);">3</span><div><div class="stage-name">提供"深入查看"选项</div><div class="stage-desc">第一眼鼓励，用户可以选择查看完整原始数据</div></div></div>
                <div class="stage-item"><span class="stage-number" style="border-style:none;background:rgba(212,165,116,0.15);">4</span><div><div class="stage-name">长期诚实 vs 短期安慰</div><div class="stage-desc">像好教练——需要鼓励时鼓励，需要直面问题时不回避</div></div></div>
              </ul>
            </div>
          </div>
          <div class="discussion anim-in">
            <div class="discussion-icon">?</div>
            <p>如果设计方案可以迁移到学钢琴、学编程、学做饭，你会选哪个？赋能和操控的边界在哪里？</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= SLIDE 5: CLOSING ================= -->
  <section class="slide" data-index="5">
    <div class="slide-inner" style="text-align:center;max-width:55rem;">
      <h2 class="closing-title-big anim-in">成长可见化</h2>
      <p class="anim-in" style="font-family:'Space Grotesk',monospace;font-size:0.85rem;color:var(--text-muted);letter-spacing:0.15em;margin-bottom:1.5rem;">MAKING GROWTH VISIBLE</p>
      <div class="divider anim-in" style="margin:1.25rem auto;"></div>
      <p class="closing-subtitle anim-in">
        也许最好的运动数据可视化，不是最精确的那个，而是最"像人"的那个。一个带有手写批注、个人情绪标记、甚至不完美涂鸦的训练日志，可能比一个精确到小数点后两位的数据仪表盘更能让人感到被理解。
      </p>
      <div class="img-frame anim-in" style="margin:2rem auto;max-width:48rem;text-align:left;">
        <img src="resources/spotify-wrapped-01.png" alt="Spotify Wrapped data storytelling" loading="lazy" style="height:280px;object-fit:cover;">
        <div class="img-caption">Spotify Wrapped — 让用户对自己的数据感到兴奋而非恐惧</div>
      </div>
      <p class="thanks-line anim-in">感谢聆听</p>
      <div class="ref-tags anim-in" style="justify-content:center;margin-top:1.5rem;">
        <span class="ref-tag">Li, Dey & Forlizzi (2010)</span>
        <span class="ref-tag">Hullman & Diakopoulos (2011)</span>
        <span class="ref-tag">Segel & Heer (2010)</span>
        <span class="ref-tag">Bandura (1977, 1997)</span>
        <span class="ref-tag">Giorgia Lupi (2017)</span>
        <span class="ref-tag">Kahneman & Tversky (1981)</span>
        <span class="ref-tag">Rooksby et al. (2014)</span>
      </div>
    </div>
  </section>

</div>

<script>
const slides = document.querySelectorAll('.slide');
const dots = document.querySelectorAll('.nav-dot');
const progressBar = document.getElementById('progress-bar');
const counterEl = document.querySelector('.slide-counter .cur');
const total = slides.length;
let current = 0;
let transitioning = false;

function goToSlide(index) {
  if (transitioning || index === current || index < 0 || index >= total) return;
  transitioning = true;

  const prev = slides[current];
  const next = slides[index];

  // Exit current
  prev.classList.remove('active');
  gsap.to(prev.querySelectorAll('.anim-in'), {
    opacity: 0,
    y: -20,
    duration: 0.3,
    stagger: 0.02,
    ease: 'power2.in',
    onComplete: () => {
      prev.style.visibility = 'hidden';
    }
  });

  // Enter next
  current = index;
  next.classList.add('active');
  next.style.visibility = 'visible';

  const elements = next.querySelectorAll('.anim-in');
  gsap.set(elements, { opacity: 0, y: 30 });
  gsap.to(elements, {
    opacity: 1,
    y: 0,
    duration: 0.7,
    stagger: 0.06,
    ease: 'power3.out'
  });

  // Update nav
  dots.forEach((d, i) => d.classList.toggle('active', i === index));
  counterEl.textContent = String(index + 1).padStart(2, '0');
  progressBar.style.width = ((index + 1) / total * 100) + '%';

  setTimeout(() => { transitioning = false; }, 500);
}

// Keyboard nav
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowDown' || e.key === 'ArrowRight' || e.key === ' ') {
    e.preventDefault(); goToSlide(current + 1);
  } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
    e.preventDefault(); goToSlide(current - 1);
  }
});

// Dot clicks
dots.forEach(d => {
  d.addEventListener('click', () => goToSlide(parseInt(d.dataset.slide)));
});

// Touch / scroll-snap on touch devices
let touchStartY = 0;
document.addEventListener('touchstart', (e) => { touchStartY = e.touches[0].clientY; }, { passive: true });
document.addEventListener('touchend', (e) => {
  const delta = touchStartY - e.changedTouches[0].clientY;
  if (Math.abs(delta) > 50) {
    goToSlide(delta > 0 ? current + 1 : current - 1);
  }
}, { passive: true });

// Mouse wheel (throttled discrete step)
let wheelTimeout = false;
document.addEventListener('wheel', (e) => {
  if (wheelTimeout) return;
  wheelTimeout = true;
  if (e.deltaY > 0) goToSlide(current + 1);
  else goToSlide(current - 1);
  setTimeout(() => { wheelTimeout = false; }, 600);
}, { passive: true });

// Init: animate first slide
gsap.set(slides[0].querySelectorAll('.anim-in'), { opacity: 0, y: 30 });
gsap.to(slides[0].querySelectorAll('.anim-in'), {
  opacity: 1,
  y: 0,
  duration: 0.7,
  stagger: 0.08,
  ease: 'power3.out'
});
</script>
</body>
</html>
